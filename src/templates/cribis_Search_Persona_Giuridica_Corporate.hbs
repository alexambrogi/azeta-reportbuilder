<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport"
    content="width=device-width, initial-scale=1.0" />
  <title>Document</title>
  <style>
    .content {
      padding: 10px 20px;
    }

    .breakPage {
      page-break-after: always;
    }

    .bold {
      color: #1f497d;
      font-size: 12pt;
      font-weight: bold;
      font-family: "Calibri";
      padding: 0 2px;
    }

    .regular {
      color: #1f497d;
      font-size: 12pt;
      font-weight: normal;
      font-family: "Calibri";
      padding: 0 10px;
    }

    .no-margin {
      margin: 0;
    }

    .no-padding {
      padding: 0;
    }

    .container__title {
      text-align: end;
      width: 100%;
      border-bottom: 2px solid #6e6e6e;
    }

    .container__title__title {
      color: #023671;
      font-size: 24pt !important;
      font-family: "Calibri";
      font-weight: normal;
    }

    h1.container__title__title {
      margin-bottom: 4px !important;
    }

    h3.container__title__subtitle {
      margin-top: 4px !important;
    }

    .container__title__subtitle {
      color: #023671;
      font-size: 16pt !important;
      font-family: "Calibri";
      font-weight: normal;
    }

    .cellSx {
      text-align: center;
      background-color: #eeeeee !important;
      width: 50%;
    }

    .cellDx {
      text-align: center;
      width: 50%;
    }

    table {
      border: 1px solid #333;
      border-spacing: 0;
      border-collapse: collapse;
    }

    td,
    th {
      border: 1px solid #333;
    }

    /* NB */

    .container__nb {
      margin-top: 5px;
      width: 100%;
    }

    .container {
      page-break-inside: avoid;
    }

    /* INDICE */

    .container__contenuti {
      padding-top: 0pt;
      padding-bottom: 0;
    }

    .container__inner_contenuti {
      padding: 1rem;
    }

    .contentuti__row {
      display: flex;
      width: 100%;
    }

    .contenuti__row__sx {
      width: 100%;
      border-bottom: 1px dotted #ccc;
    }

    .contenuti__row__dx {
      width: 10%;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    /* PIE CHART */

    .pie-chart {
      --size: 15rem;
      --fg: #369;
      width: var(--size);
      height: var(--size);
      border-radius: 50%;
      display: grid;
      place-items: center;
      position: relative;
      color: var(--fg);
    }

    .pie-chart .divider {
      height: 50%;
      left: 50%;
      margin-left: -1px;
      position: absolute;
      top: 0;
      transform-origin: 0 100%;
      transform: rotate(calc(1turn * (var(--precent) / 100)));
      width: 2px;
    }

    /* get by script */
    .table3 {
      position: relative;
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      /*  border: 1px solid white; */
    }

    .table3 th {
      color: black;
    }

    .table3 td {
      color: rgb(0, 0, 0);
    }

    .table3 th,
    .table3 td {
      border: none;
      /*  border: 1px solid rgb(255, 255, 255); */
      /* Aggiunge un bordo alle celle */
      font-size: 9px;
      /* white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis; */
    }

    .bkT2 {
      border: none;
      background-color: #023671;
      color: rgba(255, 255, 255, 0.925);
    }

    .bkT1 {
      border: none;
      background-color: #023671;
      color: rgba(255, 255, 255, 0.932);
    }

    .regular__min {
      text-align: justify;
    }

    .tableBuilding {
      width: 100%;
      border: 0.5px solid black !important;
    }

    .thBuilding {
      text-align: center;
      border: 0.5px solid black !important;
    }

    .pBuilding {
      color: #1f497d !important;
      font-size: x-small;
    }

    
  </style>
</head>

