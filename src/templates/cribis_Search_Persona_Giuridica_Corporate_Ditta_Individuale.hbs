                <h1 class="container__title__title">Rintraccio Gold</h1>
                {{/if}}
                {{#if (eq campaign_kind_id '714')}}
                <h1 class="container__title__title">Cribis Search Light</h1>
                {{/if}}
                {{#if (eq campaign_kind_id '698')}}
                <h1 class="container__title__title">Cribis Search Approfondito</h1>
                {{/if}}
                {{#if (eq campaign_kind_id '684')}}
