  <script>
    //percentuali grafico
    let pie = document.getElementById('pie');
    //const graph = [{ percentage: '#efc4ed 0 80%' }, { percentage: 'blue 80% 90%' }, { percentage: 'red 90% 100%' }];
    const graph = {{{ json members }}}
    let str = graph.map(member => member.percentage).join(',')
    pie.style.background = `radial-gradient(closest-side,white 40%,transparent 0 99.9%,white 0),conic-gradient(${str})`
  </script>
